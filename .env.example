# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
# Required. Get from: https://console.anthropic.com/
# Used by: src/lib/ai/claude.ts, all /api/ routes that call Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── App URL ──────────────────────────────────────────────────────────────────
# Required. The canonical URL of the deployed site.
# Development: http://localhost:3000
# Production: https://minar.agency
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Analytics ────────────────────────────────────────────────────────────────
# Optional. Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Email Service (Newsletter + Contact Form) ────────────────────────────────
# Optional. Used for sending transactional emails via Resend.
# Get from: https://resend.com/
# If not set, email features will log to console (dev mode fallback).
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=hello@minar.agency
RESEND_TO_EMAIL=hello@minar.agency

# ─── Mailchimp (Newsletter) ───────────────────────────────────────────────────
# Optional. Used by: src/app/api/newsletter/route.ts
# Get from: https://mailchimp.com/developer/
MAILCHIMP_API_KEY=your-key-here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your-list-id-here

# ─── Database (Future — Client Portal) ───────────────────────────────────────
# Optional. Needed only when the /dashboard route group is implemented.
# Get from: https://www.postgresql.org/ or hosted provider (Supabase, Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/minar_agency

# ─── Upstash Redis (Rate Limiting) ────────────────────────────────────────────
# Optional. Used to rate-limit AI API routes in production.
# Get from: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Sentry (Error Tracking) ──────────────────────────────────────────────────
# Optional. Used for production error monitoring.
# Get from: https://sentry.io/
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Optional. Control feature availability without redeployment.
NEXT_PUBLIC_ENABLE_CHAT_WIDGET=true
NEXT_PUBLIC_ENABLE_CALCULATOR=true
